{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecretFile",
  "type": "object",
  "required": [
    "world_id",
    "secrets"
  ],
  "properties": {
    "world_id": {
      "type": "string",
      "minLength": 1
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "objective_truth",
          "visibility",
          "knowledge_states",
          "reveal_conditions",
          "impact",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^secret_[0-9]{3}$"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "objective_truth": {
            "type": "string"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "hidden",
              "implied",
              "rumored",
              "revealed"
            ]
          },
          "knowledge_states": {
            "type": "object",
            "patternProperties": {
              "^char_[0-9]{3}$": {
                "type": "string",
                "enum": [
                  "known",
                  "partially_known",
                  "rumored",
                  "misunderstood",
                  "unknown"
                ]
              }
            },
            "additionalProperties": false
          },
          "reveal_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "impact": {
            "type": "object",
            "required": [
              "relation_targets",
              "emotion_effects",
              "world_effects"
            ],
            "properties": {
              "relation_targets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "emotion_effects": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "world_effects": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "priority": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}